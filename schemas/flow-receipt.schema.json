{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://michaelwave369.github.io/flow-covenant-runtime/schemas/flow-receipt.schema.json",
  "title": "Flow Covenant Receipt",
  "type": "object",
  "required": ["id", "createdAt", "model", "version", "scenario", "signal", "invitation", "affectedParties", "consent", "alignment", "action", "outcome", "renewal", "evidence", "assumptions", "unknowns", "gateSummary", "claimBoundary"],
  "properties": {
    "id": { "type": "string", "pattern": "^fcr-[a-f0-9]{8}$" },
    "createdAt": { "type": "string", "format": "date-time" },
    "model": { "const": "Flow Covenant Runtime" },
    "version": { "type": "string" },
    "scenario": { "type": "string" },
    "signal": { "type": "string" },
    "invitation": { "type": "string" },
    "affectedParties": { "type": "string" },
    "consent": { "type": "string" },
    "alignment": { "type": "string" },
    "action": { "type": "string" },
    "outcome": { "type": "string" },
    "renewal": { "type": "string" },
    "evidence": { "type": "string" },
    "assumptions": { "type": "string" },
    "unknowns": { "type": "string" },
    "gateSummary": { "type": "array" },
    "claimBoundary": { "type": "string", "pattern": "physical laws" }
  },
  "additionalProperties": true
}
