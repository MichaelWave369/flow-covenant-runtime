{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://michaelwave369.github.io/flow-covenant-runtime/schemas/flow-receipt.schema.json",
  "title": "Flow Covenant Receipt",
  "type": "object",
  "required": ["id", "createdAt", "model", "version", "scenarioType", "scenario", "signal", "invitation", "affectedParties", "consent", "alignment", "action", "outcome", "renewal", "evidence", "assumptions", "unknowns", "gateSummary", "gateCounts", "shareUrl", "claimBoundary"],
  "properties": {
    "id": { "type": "string", "pattern": "^fcr-[a-f0-9]{8}$" },
    "createdAt": { "type": "string", "format": "date-time" },
    "model": { "const": "Flow Covenant Runtime" },
    "version": { "type": "string" },
    "scenarioType": { "type": "string" },
    "scenario": { "type": "string" },
    "signal": { "type": "string" },
    "invitation": { "type": "string" },
    "affectedParties": { "type": "string" },
    "consent": { "type": "string" },
    "alignment": { "type": "string" },
    "action": { "type": "string" },
    "outcome": { "type": "string" },
    "renewal": { "type": "string" },
    "evidence": { "type": "string" },
    "assumptions": { "type": "string" },
    "unknowns": { "type": "string" },
    "repairPlan": { "$ref": "./repair-plan.schema.json" },
    "reversibilityAssessment": {
      "type": "object",
      "required": ["score", "label", "guidance"],
      "properties": {
        "score": { "type": "integer", "minimum": 0, "maximum": 4 },
        "label": { "enum": ["reversible", "guarded", "hard-stop"] },
        "guidance": { "type": "array", "items": { "type": "string" } }
      }
    },
    "gateSummary": { "type": "array", "items": { "type": "object", "required": ["gateId", "status", "note"], "properties": { "gateId": { "type": "string" }, "status": { "enum": ["pass", "watch", "block"] }, "note": { "type": "string" } } } },
    "gateCounts": { "type": "object", "required": ["pass", "watch", "block", "total"], "properties": { "pass": { "type": "integer" }, "watch": { "type": "integer" }, "block": { "type": "integer" }, "total": { "type": "integer" } } },
    "shareUrl": { "type": "string" },
    "savedAt": { "type": "string", "format": "date-time" },
    "claimBoundary": { "type": "string", "pattern": "physical laws" }
  },
  "additionalProperties": true
}
